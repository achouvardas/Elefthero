# Copy this file to .env, set a strong SECRET_KEY, then keep .env outside Git.
# AADE, Resend, Turnstile, and 2FA secrets are configured after first login in
# the Elefthero UI and encrypted in the local database.

# Required for any deployed instance. Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-value

# Runtime defaults. Settings controls the active AADE environment after setup.
MYDATA_MODE=test
PORT=5000
FLASK_DEBUG=0

# Optional. The default is sqlite:///myaade.sqlite3 in the Flask instance path.
# DATABASE_URL=sqlite:////absolute/path/to/elefthero.sqlite3

# Optional legacy issuer VAT fallback. Prefer Business Profile in the UI.
# MYDATA_VAT_NUMBER=
